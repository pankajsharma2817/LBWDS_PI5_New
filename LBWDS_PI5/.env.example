# ============================================================
# LBWDS - Environment variables
# ============================================================
# Copy this file to `.env` and fill in your real credentials.
# NEVER commit the real .env file — it is listed in .gitignore.
# ============================================================

# --- Gmail SMTP (emailer.py) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_gmail_app_password
EMAIL_TO=recipient@example.com

# --- Admin email (receives copy of unauthorized-entry alerts) ---
ADMIN_EMAIL=admin@example.com

# --- httpSMS / SMS Gateway (server_main3.py) ---
SMS_ACCOUNT_KEY=uk_your_account_key_here
SMS_SENDER=+91XXXXXXXXXX
SMS_PHONE_IP=192.168.x.x
SMS_LOCAL_PORT=8080
SMS_CLOUD_SERVER=https://api.sms-gate.app:443
SMS_USERNAME=your_username
SMS_PASSWORD=your_password
SMS_DEVICE_ID=your_device_id

# --- Face recognition database path (Excel file) ---
FACE_DB_PATH=/home/pi/Desktop/LBWDS/face_db/faces-1.xlsx

# --- Capture output directory ---
IMG_DIR=/home/pi/Desktop/captured_images

# --- Sensor fusion CSV log path ---
FUSION_LOG=/home/pi/mqtt_bridge/sensor_fusion.csv

# --- MQTT broker (mqtt_publisher.py) ---
# For HiveMQ Cloud or any TLS broker: port 8883, MQTT_USE_TLS=true
# For local Mosquitto (no TLS): port 1883, MQTT_USE_TLS=false
MQTT_BROKER_HOST=your-broker.example.com
MQTT_BROKER_PORT=8883
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password
MQTT_USE_TLS=true
MQTT_CLIENT_ID=lbwds_node1_pi5

# MQTT topic names (defaults shown — leave as-is unless you have a reason)
MQTT_TOPIC_EVENTS=lbwds/events
MQTT_TOPIC_IMAGES=lbwds/images
MQTT_TOPIC_STATUS=lbwds/status
